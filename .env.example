# ------------------------------------------------------------------
# FlowMind AI - Environment Variables
# Copy this file to ".env" and fill in your own keys.
# Leave a key empty to leave that agent/provider disabled — it will
# return a clear "not configured" error instead of crashing.
# ------------------------------------------------------------------

# Google Gemini — used by: Chat (Brain), Image Agent, Video Agent, Voice Agent
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
GEMINI_VIDEO_MODEL=veo-3.0-generate-001
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# OpenAI — optional alternate chat provider (not required)
OPENAI_API_KEY=

# ElevenLabs — optional alternate voice provider (not required if using Gemini TTS)
ELEVENLABS_API_KEY=

# GitHub — used by: Deployment Agent (to pull latest code) and GitHub tool
# Create a classic token with "repo" scope at: https://github.com/settings/tokens
GITHUB_TOKEN=

DATABASE_URL=sqlite:///./flowmind.db

DEBUG=True
